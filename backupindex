    <style>
        @import url('https://fonts.googleapis.com/css2?family=Anton&family=Inter:wght@300;400;600&display=swap');

        :root {
            --bg-color: #f1efea;
            --accent-red: #ea2727;
            --text-dark: #222222;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-color);
            color: var(--text-dark);
            overflow-x: hidden; /* Mencegah scroll horizontal */
            scroll-behavior: smooth;
        }

        /* Layout Section Standard */
        section {
            min-height: 100vh;
            padding: 6rem 10%;
            display: flex;
            flex-direction: column;
            justify-content: center;
            /* border-bottom: 1px solid #e0ddd5; */
			border-bottom: none;
        }

        /* Tipografi */
        h1, h2, h3 {
            font-family: 'Anton', sans-serif;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--accent-red);
        }

        h1 { font-size: clamp(4rem, 10vw, 8rem); line-height: 1; margin-bottom: 1rem; }
        h2 { font-size: clamp(3rem, 6vw, 5rem); margin-bottom: 1.5rem; }
        
        p, li {
            font-size: 1.15rem;
            line-height: 1.8;
            margin-bottom: 1rem;
        }

        /* Layout Grid */
        .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
        .grid-3 { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2rem; }

        .meta-info {
            display: flex; justify-content: space-between;
            border-top: 1px solid var(--text-dark);
            border-bottom: 1px solid var(--text-dark);
            padding: 15px 0; margin-top: 2rem; font-weight: 600; font-size: 0.9rem;
        }

        .box { background: var(--text-dark); color: white; padding: 3rem 2rem; text-align: center; }
        .box h3 { color: white; font-family: 'Inter', sans-serif; font-size: 1.5rem; margin-bottom: 1rem;}

        /* =========================================
           ANIMASI SMOOTH (Sistem Reset & Reveal)
           ========================================= */
        
        /* State Awal (Disembunyikan & Digeser) */
        .hidden-up {
            opacity: 0;
            transform: translateY(60px);
            transition: opacity 0.8s ease-out, transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        }

        .hidden-left {
            opacity: 0;
            transform: translateX(-60px);
            transition: opacity 0.8s ease-out, transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        }

        .hidden-right {
            opacity: 0;
            transform: translateX(60px);
            transition: opacity 0.8s ease-out, transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        }

        .hidden-scale {
            opacity: 0;
            transform: scale(0.85);
            transition: opacity 0.8s ease-out, transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        }

        /* State Aktif (Saat di-scroll masuk viewport) */
        .show {
            opacity: 1 !important;
            transform: translate(0) scale(1) !important;
        }

        /* Transisi Delay agar elemen muncul berurutan */
        .delay-100 { transition-delay: 0.1s; }
        .delay-200 { transition-delay: 0.2s; }
        .delay-300 { transition-delay: 0.3s; }
        .delay-400 { transition-delay: 0.4s; }

        /* Media Query untuk Mobile */
        @media (max-width: 768px) {
            .grid-2 { grid-template-columns: 1fr; gap: 2rem; }
            .hidden-left, .hidden-right { transform: translateY(40px); /* Ubah slide miring jadi vertikal di HP */ }
        }

