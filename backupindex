    <script>
        document.addEventListener("DOMContentLoaded", function() {
            // Memilih semua elemen yang memiliki kelas animasi awalan "hidden-"
            const animElements = document.querySelectorAll('.hidden-up, .hidden-left, .hidden-right, .hidden-scale');

            // Konfigurasi Observer
            const observerOptions = {
                root: null,
                rootMargin: '0px',
                threshold: 0.15 // Animasi mulai saat elemen 15% terlihat di layar
            };

            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        // Jika masuk ke layar, tambahkan class 'show' untuk menjalankan animasi
                        entry.target.classList.add('show');
                    } else {
                        // JIKA KELUAR LAYAR, HAPUS CLASS 'show'. 
                        // Ini akan me-reset animasi agar bisa dimainkan lagi saat discroll kembali.
                        entry.target.classList.remove('show');
                    }
                });
            }, observerOptions);

            // Terapkan observer ke semua elemen
            animElements.forEach(el => observer.observe(el));
        });
    </script>
